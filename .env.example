# =============================================================================
# Feature flags — toggle product behavior (values: 1/true/yes or 0/false/no)
# =============================================================================

# Stripe tier gating: shift limits, roster cap, scheduler, paper trading, social publish.
# Off (default): all features open. On: free tier enforced; Pro/Day Pass unlock via Stripe.
PAYWALL_ENABLED=0

# Parent desks spawn focused sub-analysts before writing thesis. Off: single-pass analysis only.
SUB_AGENTS=1
# Max sub-agents per desk when SUB_AGENTS is on.
MAX_SUB_AGENTS=2

# Risk inventory + scenario pipeline before thesis. Off: skip risk stage entirely.
RISK_PIPELINE=1

# LLM-generated bespoke matplotlib chart in shift artifacts. Off: template charts only.
CUSTOM_ARTIFACT_CHARTS=1

# Global kill switch for Alpaca paper execution after shifts. On: blocks even if user keys exist.
ALPACA_PAPER_DISABLED=0

# Rich terminal progress UI during CLI/agent runs (not the web floor). On: live TUI in terminal.
PROGRESS_TUI=0

# production — strict startup validation (SUPABASE_URL, SERVICE_ROLE_KEY, SCORING_CRON_SECRET).
# Also aliases ENVIRONMENT. Unset = development/local.
# ENV=development

# Trust X-Forwarded-For for API rate limits. On when behind ALB, nginx, or Cloudflare.
# TRUST_PROXY=0

# --- Implicit behavior (not boolean flags, but toggle features when set/unset) ---
# SUPABASE_URL — when set: JWT auth required on protected routes; per-user entitlements & schedules.
#   When unset: anonymous local dev; unlimited shifts without sign-in.
# STRIPE_SECRET_KEY — when set: checkout & webhooks active. When unset: billing UI no-ops gracefully.
# RESEND_API_KEY — when set: boss memo email digest after shifts. When unset: email skipped.
# OPENROUTER_API_KEY — when set: server-side scheduler chat & cron-fired scheduled shifts.
# SCHEDULE_CRON_SECRET — when set: enables POST /hedge-fund/schedules/run for external cron.
# SCORING_CRON_SECRET — when set: enables POST /hedge-fund/scoring/run for agent scorecards.
# DIGEST_CRON_SECRET — when set: enables POST /hedge-fund/digest/run for digest jobs.

# For getting financial data to power the hedge fund
# Get your Financial Datasets API key from https://financialdatasets.ai/
# Free without a key for: AAPL, GOOGL, MSFT, NVDA, TSLA
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Optional fallbacks (used automatically when earlier providers fail)
# FMP free tier: https://site.financialmodelingprep.com/developer/docs/
FMP_API_KEY=your-fmp-api-key
# Finnhub free tier: https://finnhub.io/
FINNHUB_API_KEY=your-finnhub-api-key
# Alpha Vantage free tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
# MarketAux news + sentiment: https://www.marketaux.com/
MARKETAUX_API_KEY=your-marketaux-api-key

# FRED macro data (free): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# Polygon.io / Massive (prices): https://polygon.io/
POLYGON_API_KEY=your-polygon-api-key

# Tiingo (prices + fundamentals): https://www.tiingo.com/
TIINGO_API_KEY=your-tiingo-api-key

# Twelve Data (prices + statistics): https://twelvedata.com/
TWELVE_DATA_API_KEY=your-twelve-data-api-key

# EOD Historical Data (prices + fundamentals): https://eodhistoricaldata.com/
EODHD_API_KEY=your-eodhd-api-key

# SimFin (prices + standardized statements): https://simfin.com/data/api
SIMFIN_API_KEY=your-simfin-api-key

# BLS labor/inflation data uses Public API v1 (no key required)

# SEC EDGAR requires a descriptive User-Agent (no key) — used for earnings 8-K/10-Q digest
SEC_EDGAR_USER_AGENT=YourName your.email@example.com

# For running LLMs hosted by openai (GPT 5, etc.)
# Get your OpenAI API key from https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key

# For running LLMs hosted by anthropic (claude-4-sonnet, claude-4.1-opus, etc.)
# Get your Anthropic API key from https://anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# For running LLMs hosted by deepseek (deepseek-chat, deepseek-reasoner, etc.)
# Get your DeepSeek API key from https://deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key

# For running LLMs hosted by groq (deepseek, llama3, etc.)
# Get your Groq API key from https://groq.com/
GROQ_API_KEY=your-groq-api-key

# For running LLMs hosted by gemini (gemini-2.5-flash, gemini-2.5-pro)
# Get your Google API key from https://ai.dev/
GOOGLE_API_KEY=your-google-api-key

# For running LLMs hosted by xAI (Grok 4, etc.)
XAI_API_KEY=your-xai-api-key

# For running LLMs hosted by Moonshot / Kimi (kimi-k2, kimi-latest, moonshot-v1-*)
# Get your Moonshot API key from https://platform.moonshot.ai/
# Mainland China users: set MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=your-moonshot-api-key

# For running LLM GigaChat
GIGACHAT_API_KEY=your-gigachat-api-key

# For running LLMs hosted by OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional OpenRouter attribution headers
YOUR_SITE_URL=https://github.com/AuthByte/the-floor2
YOUR_SITE_NAME=THE FLOOR

# Alpaca paper trading (optional — executes boss decisions after each shift)
# Sign up at https://alpaca.markets/ then open Paper Trading → API Keys
# Paper API base URL (default shown; only change if Alpaca docs specify otherwise)
ALPACA_API_KEY_ID=your-alpaca-paper-key-id
ALPACA_API_SECRET_KEY=your-alpaca-paper-secret
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# Resend — email boss memo digest after each shift (optional)
# API key: https://resend.com/api-keys
# Until you verify a domain, use onboarding@resend.dev (test sends only to your Resend account email)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=Boss Memo <onboarding@resend.dev>

# For running LLMs hosted by Microsoft Azure OpenAI (gpt-4o, gpt-4o-mini, etc.)
# Get your Azure OpenAI API settings from https://oai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment-name

# --- Production / AWS deployment ---
# See feature flags at top of file for ENV, TRUST_PROXY, and cron secrets.
# Comma-separated frontend origins allowed by CORS (required when not using localhost)
# CORS_ORIGINS=https://your-frontend.vercel.app,https://floor.yourdomain.com
# SCORING_CRON_SECRET=generate-a-long-random-string
# DIGEST_CRON_SECRET=generate-a-long-random-string
# SCHEDULE_CRON_SECRET=generate-a-long-random-string
# Model used for server-side scheduled shifts (uses OPENROUTER_API_KEY above)
# SCHEDULED_SHIFT_MODEL=openrouter/owl-alpha
# With Supabase Storage for artifacts + shifts, EFS is optional — remove the volume to cut AWS cost.
# DATA_DIR=/data
# ARTIFACT_DIR=/data/artifacts

# --- Supabase Auth (project: the-floor) ---
# Dashboard: https://supabase.com/dashboard/project/bhtpnjvtsinzjxdglobo
# Backend (repo root .env) — required for public replay links (?replay=<postId>), billing, schedules
# Frontend (app/frontend/.env): VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY
# Backend JWT verification uses Supabase JWKS when SUPABASE_URL is set (no JWT secret required).
# Optional legacy fallback: SUPABASE_JWT_SECRET=...
SUPABASE_URL=https://bhtpnjvtsinzjxdglobo.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Required in production for /public/* routes and server-side Supabase writes
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional: direct Postgres for legacy flow routes (Settings → Database → connection string)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# SUPABASE_ARTIFACT_BUCKET=shift-artifacts

# --- Stripe billing (optional — graceful no-op in dev when unset) ---
# See PAYWALL_ENABLED in feature flags section at top of file.
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret from Stripe CLI (`stripe listen`) or Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Price IDs from Products → each price row in Stripe Dashboard
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_your_pro_yearly_id
STRIPE_PRICE_DAY_PASS=price_your_day_pass_id