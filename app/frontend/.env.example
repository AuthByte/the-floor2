# =============================================================================
# Frontend feature flags (app/frontend/.env — copy from this file)
# =============================================================================

# Skip the 7am–6pm ET floor-hours gate in production builds (floor always "open").
# Dev and localhost always skip hours. Do not set true in production unless intentional.
VITE_FLOOR_ALWAYS_OPEN=false

# =============================================================================
# Frontend configuration
# =============================================================================

# Supabase project: the-floor (bhtpnjvtsinzjxdglobo)
VITE_SUPABASE_URL=https://bhtpnjvtsinzjxdglobo.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API base URL — required for public embed/replay on non-localhost builds.
# Dev default: http://localhost:8000 (when hostname is localhost).
# Production: set to your FastAPI origin, e.g. https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# Canonical app origin for share links (?replay=, ?embed=). Defaults to window.location.origin.
# VITE_APP_URL=https://thefloor.app
