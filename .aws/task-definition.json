{
  "family": "the-floor-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::967512078853:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::967512078853:role/the-floor-api-task",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "967512078853.dkr.ecr.us-east-1.amazonaws.com/the-floor-api:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8000, "protocol": "tcp" }],
      "environment": [
        { "name": "DATA_DIR", "value": "/data" },
        { "name": "ARTIFACT_DIR", "value": "/data/artifacts" },
        { "name": "CORS_ORIGINS", "value": "http://localhost:5173,http://127.0.0.1:5173" }
      ],
      "secrets": [
        { "name": "OPENROUTER_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:OPENROUTER_API_KEY::" },
        { "name": "ALPACA_API_KEY_ID", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:ALPACA_API_KEY_ID::" },
        { "name": "ALPACA_API_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:ALPACA_API_SECRET_KEY::" },
        { "name": "ALPACA_PAPER_BASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:ALPACA_PAPER_BASE_URL::" },
        { "name": "FMP_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:FMP_API_KEY::" },
        { "name": "FINNHUB_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:FINNHUB_API_KEY::" },
        { "name": "ALPHA_VANTAGE_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:ALPHA_VANTAGE_API_KEY::" },
        { "name": "MARKETAUX_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:MARKETAUX_API_KEY::" },
        { "name": "FRED_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:FRED_API_KEY::" },
        { "name": "POLYGON_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:POLYGON_API_KEY::" },
        { "name": "TIINGO_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:TIINGO_API_KEY::" },
        { "name": "TWELVE_DATA_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:TWELVE_DATA_API_KEY::" },
        { "name": "EODHD_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:EODHD_API_KEY::" },
        { "name": "SIMFIN_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:SIMFIN_API_KEY::" },
        { "name": "SEC_EDGAR_USER_AGENT", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:SEC_EDGAR_USER_AGENT::" },
        { "name": "RESEND_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:RESEND_API_KEY::" },
        { "name": "RESEND_FROM", "valueFrom": "arn:aws:secretsmanager:us-east-1:967512078853:secret:the-floor/prod-48goq3:RESEND_FROM::" }
      ],
      "mountPoints": [{ "sourceVolume": "data", "containerPath": "/data", "readOnly": false }],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/the-floor-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "api"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 120
      }
    }
  ],
  "volumes": [
    {
      "name": "data",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-04fd43219700fbf40",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-0d4bf2d461fd9f340",
          "iam": "ENABLED"
        }
      }
    }
  ]
}
